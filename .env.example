# ── Neural Router v4 — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

GROQ_API_KEY=gsk_your_key_here

# Path to your downloaded model file
MODEL_PATH=./model/nanoqa_v4_best.pt

# Confidence thresholds
CONF_ACCEPT=0.60
CONF_RETRY=0.45

# Groq model names (free tier)
GROQ_MID_MODEL=gemma2-9b-it
GROQ_TOP_MODEL=llama-3.3-70b-versatile
